class Solution {
public:
   void solve(TreeNode *root,vector<int>&res){
        if(root==null){
            return ;
        }
        solve(root.left,res);
        solve(root.right,res);
        res.add(root.val);
    }
}

    vector<int> postorderTraversal(TreeNode* root) {
         if(root==NULL){
            return {};
        }
        vector<int>res;
        stack<TreeNode*>st;
        st.push(root);
        // solve(root,res);
        while(!st.empty()){
            auto node=st.top();
            st.pop();
            res.push_back(node->val);
            
             if(node->left!=NULL)
               st.push(node->left);
            if(node->right!=NULL)
               st.push(node->right);
        }
        reverse(res.begin(),res.end());
        return res;
    }
};
