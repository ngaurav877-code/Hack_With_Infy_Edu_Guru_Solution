// problem link  : https://leetcode.com/problems/binary-tree-preorder-traversal/description/
class Solution {
public:
 void recur(TreeNode *root,vector<int>&res){
         if(root==NULL){
            return;
         }
         solve(root->left,res);
         res.push_back(root->val);
         solve(root->right,res);
    }
    vector<int> inorderTraversal(TreeNode* root) {
        if(root==NULL){
            return {};
        }
        vector<int>res;
        stack<TreeNode*>st;
        TreeNode *curr=root;
        while(curr!=NULL || !st.empty()){
            while(curr!=NULL){// exlore left
                st.push(curr);
                curr=curr->left;
            }
            curr=st.top();
            st.pop();
            res.push_back(curr->val);// visit node
           
            curr=curr->right;
        }
        return res;

        
    }
};
