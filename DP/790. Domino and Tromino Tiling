class Solution {
public:
    const int mod=1e9+7;
    int numTilings(int n) {
        if(n==1){
            return 1;
        }
        if(n==2){
            return 2;
        }
        if(n==3){
            return 5;
        }
        int prev3=1,prev2=2,prev1=5;
        for(int i=4; i<=n; i++){
            int curr=(1LL*2*prev1+prev3)%mod;
            prev3=prev2;
            prev2=prev1;
            prev1=curr;
        }
        return prev1;







        
    }
};
