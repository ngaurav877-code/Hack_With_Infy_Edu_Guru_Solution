class Solution {
public:
     int rob1(vector<int>& nums) {
        int n=nums.size();
        if(n==1){
            return nums[0];
        }
        if(n==2){
            return max(nums[0],nums[1]);
        }
        int x=nums[0];
        int y=max(nums[0],nums[1]);
        for(int i=2; i<n; i++){
            int curr=max(nums[i]+x,y);
            x=y;
            y=curr;
        }
        return y;
       
        
    }
    int rob(vector<int>& nums) {
        int n=nums.size();
        if(n==1){
            return nums[0];
        }
        if(n==2){
            return max(nums[0],nums[1]);
        }
        vector<int>v1=vector<int>(nums.begin(),nums.begin()+n-1);
        vector<int>v2=vector<int>(nums.begin()+1,nums.end());
        return max(rob1(v1),rob1(v2));
        
    }
};
